# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/forum_db

# Authentication
JWT_SECRET=change-this-secret-in-your-local-env

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug

# Public URL used in password-reset links
APP_URL=http://127.0.0.1:5000

# SMTP email delivery (port 465 normally uses true; port 587 uses false)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
MAIL_FROM=Thread Quest <no-reply@example.com>
